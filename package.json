{
  "name": "dave",
  "private": true,
  "version": "0.0.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"API,BOT,GW,BILLING\" --prefix-colors \"cyan,green,yellow,magenta\" \"bun run dev:api\" \"bun run dev:bot-worker\" \"bun run dev:gateway\" \"bun run dev:billing-worker\"",
    "dev:gateway": "bun --env-file=.env run --cwd apps/gateway dev",
    "dev:bot-worker": "bun --env-file=.env run --cwd apps/bot-worker dev",
    "dev:api": "bun --env-file=.env run --cwd apps/api dev",
    "dev:billing-worker": "bun --env-file=.env run --cwd apps/billing-worker dev",
    "typecheck": "bun run --filter='*' typecheck",
    "db:generate": "bun run --cwd packages/database db:generate",
    "db:migrate": "bun run --cwd packages/database db:migrate",
    "db:migrate:dev": "bun run --cwd packages/database db:migrate:dev",
    "db:studio": "bun run --cwd packages/database db:studio",
    "deploy-commands": "bun --env-file=.env run --cwd apps/bot-worker deploy-commands"
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "concurrently": "^10.0.3"
  }
}
