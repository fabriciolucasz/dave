# =============================================================================
# Dave Bot — .gitignore central do monorepo
#
# Estratégia: um único .gitignore na raiz cobre todas as apps e packages.
# Padrões com **/ se aplicam recursivamente em qualquer nível da árvore.
# =============================================================================

# -----------------------------------------------------------------------------
# Dependências
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/

# -----------------------------------------------------------------------------
# Ambiente & Segredos
# NÃO versionar .env — use .env.example como referência.
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
**/.env
**/.env.local

# -----------------------------------------------------------------------------
# Build & Compilação
# -----------------------------------------------------------------------------
dist/
**/dist/
build/
**/build/
out/
**/out/

# Bun cache e artefatos de build
.bun/
**/.bun-cache/

# TypeScript incremental
*.tsbuildinfo
**/*.tsbuildinfo

# Turbo cache
.turbo/
**/.turbo/

# -----------------------------------------------------------------------------
# Prisma
# O cliente gerado é derivado do schema.prisma + versão do Prisma.
# É reconstruído com `bun run prisma generate` — não deve ser commitado.
# As migrations (SQL) SÃO versionadas — ficam em prisma/migrations/.
# -----------------------------------------------------------------------------
**/prisma/generated/
# .env dentro do package database (caso exista local override)
packages/database/.env

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
*.log.*
logs/
**/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-error.log*
pnpm-debug.log*

# -----------------------------------------------------------------------------
# Cobertura de testes
# -----------------------------------------------------------------------------
coverage/
**/coverage/
.nyc_output/
**/.nyc_output/

# -----------------------------------------------------------------------------
# Docker
# Volumes locais e dados persistidos pelo docker compose.
# -----------------------------------------------------------------------------
.docker-data/
docker-volumes/
# Arquivos de override local do compose
docker-compose.override.yml
docker-compose.local.yml

# -----------------------------------------------------------------------------
# IDEs e Editores
# -----------------------------------------------------------------------------

# VS Code — configurações locais (launch configs e settings pessoais ficam fora)
.vscode/settings.json
.vscode/launch.json
.vscode/*.code-workspace

# Manter extensões recomendadas e tasks versionadas (útil para o time)
!.vscode/extensions.json
!.vscode/tasks.json

# JetBrains (IntelliJ, WebStorm, Rider)
.idea/
*.iml
*.iws
*.ipr

# Vim/Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# -----------------------------------------------------------------------------
# SO
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------

# Artefatos temporários de debug
*.heapprofile
*.heapsnapshot
*.cpuprofile

# Relatórios
*.lcov

# Pacotes locais
*.tgz
*.tar.gz
