// packages/database/prisma/schema.prisma
//
// Autenticação do frontend é via Discord OAuth2 —
// não guardamos senha nenhuma, só os dados retornados pelo Discord.
//
// Regra de acesso adotada (ver PLAN.md seção "Controle de acesso"):
// qualquer membro com permissão ADMINISTRATOR (ou MANAGE_GUILD) no servidor
// pode configurar e assinar o bot. Para manter rastreabilidade, toda ação
// sensível grava quem fez (AuditLog) e toda assinatura grava quem criou
// (Subscription.createdByUserId).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Usuários (autenticados via Discord OAuth2)
// ---------------------------------------------------------------------------

model User {
  id            String   @id @default(uuid())
  discordId     String   @unique
  username      String
  discriminator String? // legado, discord não usa mais na maioria das contas
  globalName    String? // "display name" novo do Discord
  avatarHash    String?
  email         String? // vem do escopo `email` do OAuth2, pode ser null se usuário negar o escopo

  // tokens do OAuth2, usados para refresh de sessão e para buscar guilds do usuário
  accessToken  String?
  refreshToken String?
  tokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedGuilds        Guild[]             @relation("GuildOwner")
  memberships        GuildMember[]
  createdSubscriptions Subscription[]    @relation("SubscriptionCreatedBy")
  auditLogs          AuditLog[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// Servidores (guilds) onde o bot está instalado
// ---------------------------------------------------------------------------

model Guild {
  id        String  @id @default(uuid())
  discordId String  @unique
  name      String
  iconHash  String?

  // dono atual do servidor no Discord (pode não ter conta no nosso sistema ainda)
  ownerDiscordId String
  owner          User?  @relation("GuildOwner", fields: [ownerUserId], references: [id])
  ownerUserId    String?

  botAddedAt DateTime  @default(now())
  botRemovedAt DateTime? // preenchido se o bot for removido/kickado, para histórico
  isActive   Boolean   @default(true)
  // true somente quando o bot de fato entrou na guild (handleGuildOnboarding).
  // Nunca escrito pelo upsert de login (auth callback) nem pelo guild-sync do
  // billing-worker — ambos podem criar/atualizar Guild rows para guilds "fantasma"
  // (o usuário administra o servidor no Discord, mas o bot nunca foi adicionado).
  botPresent Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members       GuildMember[]
  subscriptions Subscription[]
  auditLogs     AuditLog[]
  settings      GuildSettings?
  containers    GuildContainer[]
  inventoryItems         InventoryItem[]
  inventoryMovements     InventoryMovement[]
  inventoryLocations     InventoryLocation[]
  illegalActions         IllegalAction[]
  illegalActionCities    IllegalActionCity[]
  illegalActionTypes     IllegalActionType[]
  weeklyGoalSubmissions  WeeklyGoalSubmission[]
  characterRegistrations CharacterRegistration[]
  featureLogConfigs      FeatureLogConfig[]

  @@map("guilds")
}

// ---------------------------------------------------------------------------
// Cache de "quem tem acesso a qual guild e com que permissão"
// Evita bater no Discord toda vez que o dashboard carrega; sincronizado
// no login e periodicamente.
// ---------------------------------------------------------------------------

model GuildMember {
  id      String @id @default(uuid())
  guildId String
  userId  String

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  // bitfield de permissões do discord (string pois é um BigInt serializado)
  permissions String
  isOwner     Boolean @default(false)
  isAdmin     Boolean @default(false) // calculado a partir do bitfield, para query rápida

  lastSyncedAt DateTime @default(now())

  @@unique([guildId, userId])
  @@index([userId])
  @@map("guild_members")
}

// ---------------------------------------------------------------------------
// Configurações do servidor (branding, prefixos, canais padrão, etc)
// Separado da Guild para não inchar a tabela principal.
// ---------------------------------------------------------------------------

model GuildSettings {
  id      String @id @default(uuid())
  guildId String @unique
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  locale       String  @default("pt-BR")
  embedColor   String? // cor padrão dos embeds/containers do servidor
  logChannelId String? // canal onde o bot posta logs de ações administrativas

  // Setup via /setup wizard — canal e roles configurados pelo admin
  defaultChannelId String?  // canal padrão para postagem do bot
  allowedRoleIds   String[] // roles que têm permissão para interagir com o bot

  // JSON livre para configs específicas de módulos (economia, RP, moderação...)
  // evita ter que migrar o schema toda vez que um módulo novo precisa de 1 config
  data Json @default("{}")

  updatedAt DateTime @updatedAt

  @@map("guild_settings")
}

// ---------------------------------------------------------------------------
// Planos disponíveis (catálogo)
// ---------------------------------------------------------------------------

model Plan {
  id          String  @id @default(uuid())
  code        String  @unique // ex: "free", "pro", "business"
  name        String
  priceCents  Int
  currency    String  @default("BRL")
  interval    BillingInterval @default(MONTHLY)
  features    Json    // lista/flags de recursos liberados nesse plano
  isActive    Boolean @default(true)

  stripePriceId String? // id do price no Stripe, se aplicável

  subscriptions Subscription[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("plans")
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

// ---------------------------------------------------------------------------
// Assinaturas — vinculadas à guild, não ao usuário.
// Guardamos quem criou/gerencia por rastreabilidade e suporte.
// ---------------------------------------------------------------------------

model Subscription {
  id      String @id @default(uuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  planId String
  plan   Plan   @relation(fields: [planId], references: [id])

  // usuário que assinou/paga atualmente — não necessariamente o dono do servidor
  createdByUserId String
  createdBy       User   @relation("SubscriptionCreatedBy", fields: [createdByUserId], references: [id])

  status             SubscriptionStatus @default(ACTIVE)
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  canceledAt         DateTime?
  cancelReason       String?

  // integração com o provedor de pagamento
  provider               PaymentProvider @default(MERCADO_PAGO)
  providerCustomerId     String? // ex: customer_id no MP
  providerSubscriptionId String? @unique // ex: preapproval_id no MP ou sub_xxx no Stripe

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId, status])
  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  TRIALING
}

enum PaymentProvider {
  STRIPE
  MERCADO_PAGO
}

// ---------------------------------------------------------------------------
// Containers persistentes ("Sticky Messages")
// Mensagens/containers fixados num canal que são automaticamente repostados
// quando deletados.
// ---------------------------------------------------------------------------

model GuildContainer {
  id      String @id @default(uuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  channelId String  // canal onde o container está fixado
  messageId String? // null quando a mensagem foi deletada, aguardando repost

  // tipo semântico do container (ex: "rules", "welcome", "custom")
  type    String
  // payload serializado do container (estrutura de embeds/components v2)
  payload Json

  isActive    Boolean @default(true)
  repostDelay Int     @default(30) // segundos de delay antes de repostar após delete

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId, isActive])
  @@index([messageId]) // lookup rápido no messageDelete
  @@map("guild_containers")
}

// ---------------------------------------------------------------------------
// Audit log — registra quem fez o quê. Essencial dado que múltiplos admins
// podem configurar/assinar o mesmo servidor.
// ---------------------------------------------------------------------------

model AuditLog {
  id      String @id @default(uuid())
  guildId String
  guild   Guild  @relation(fields: [guildId], references: [id], onDelete: Cascade)

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action   String // ex: "subscription.created", "settings.updated", "member.kicked_bot"
  metadata Json   @default("{}") // detalhes específicos da ação (diff de config, plano anterior, etc)

  createdAt DateTime @default(now())

  @@index([guildId, createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Sistema de Baú (Inventário Compartilhado)
// ---------------------------------------------------------------------------

model InventoryItem {
  id              String   @id @default(uuid())
  guildId         String
  guild           Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // Localização opcional — null = item pertence ao "baú geral" sem localização específica
  locationId      String?
  location        InventoryLocation? @relation(fields: [locationId], references: [id])
  name            String
  description     String?
  iconUrl         String?
  currentQuantity Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  movements       InventoryMovement[]

  @@index([guildId, isActive])
  @@index([locationId])
  @@map("inventory_items")
}

model InventoryMovement {
  id                String   @id @default(uuid())
  itemId            String
  item              InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  guildId           String
  guild             Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  quantityDelta     Int
  resultingQuantity Int
  performedByUserId String   // Discord User ID or internal user ID
  reason            String?
  createdAt         DateTime @default(now())

  @@index([guildId, itemId])
  @@map("inventory_movements")
}

// ---------------------------------------------------------------------------
// Localizações de Baú (ex: QG, Casa X, Casa Y)
// Seção 26.1 do PLAN.md
// ---------------------------------------------------------------------------

model InventoryLocation {
  id             String   @id @default(uuid())
  guildId        String
  guild          Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name           String
  // roles com permissão de ver esta localização — vazio = visível a todos
  allowedRoleIds String[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          InventoryItem[]

  @@index([guildId])
  @@map("inventory_locations")
}

// ---------------------------------------------------------------------------
// Sistema de Central de Ações & Metas Semanais
// ---------------------------------------------------------------------------

model IllegalAction {
  id                String   @id @default(uuid())
  guildId           String
  guild             Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  // Cidade e tipo de ação são obrigatórios para novos registros (seção 26.2).
  // nullable para retrocompatibilidade com registros históricos sem cidade/tipo.
  cityId            String?
  city              IllegalActionCity? @relation(fields: [cityId], references: [id])
  actionTypeId      String?
  actionType        IllegalActionType? @relation(fields: [actionTypeId], references: [id])
  outcome           String   // "WON" | "LOST"
  amount            Int
  registeredByUserId String
  createdAt         DateTime @default(now())

  participants      IllegalActionParticipant[]

  @@index([guildId])
  @@index([cityId])
  @@map("illegal_actions")
}

model IllegalActionParticipant {
  id            String        @id @default(uuid())
  actionId      String
  action        IllegalAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  discordUserId String
  shareAmount   Int?

  @@index([actionId])
  @@map("illegal_action_participants")
}

// ---------------------------------------------------------------------------
// Cidades e Tipos de Ação Ilegal (configuráveis por servidor)
// Seção 26.2 do PLAN.md
// ---------------------------------------------------------------------------

model IllegalActionCity {
  id        String   @id @default(uuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  actionTypes IllegalActionType[]
  actions     IllegalAction[]

  @@index([guildId])
  @@map("illegal_action_cities")
}

model IllegalActionType {
  id              String            @id @default(uuid())
  cityId          String
  city            IllegalActionCity @relation(fields: [cityId], references: [id], onDelete: Cascade)
  guildId         String
  guild           Guild             @relation(fields: [guildId], references: [id], onDelete: Cascade)
  name            String
  // null = usa o limite padrão configurado em GuildSettings.data.defaultMaxParticipants
  maxParticipants Int?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  actions         IllegalAction[]

  @@index([cityId])
  @@index([guildId])
  @@map("illegal_action_types")
}

model WeeklyGoalSubmission {
  id                String   @id @default(uuid())
  guildId           String
  guild             Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  discordUserId     String
  weekStartDate     DateTime
  amountDelivered   Int
  registeredByUserId String
  createdAt         DateTime @default(now())

  @@index([guildId, discordUserId, weekStartDate])
  @@map("weekly_goal_submissions")
}

// ---------------------------------------------------------------------------
// Sistema de Cadastro de Personagem
// ---------------------------------------------------------------------------

model CharacterRegistration {
  id                   String   @id @default(uuid())
  guildId              String
  guild                Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  discordUserId        String
  characterName        String
  characterServerId    Int
  phoneNumber          String
  referredByUserId     String?
  status               String   // "PENDING" | "VERIFIED" | "MISMATCH" | "REJECTED"
  nicknameAtSubmission String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([guildId, discordUserId])
  @@map("character_registrations")
}

// ---------------------------------------------------------------------------
// Configurações de Log
// ---------------------------------------------------------------------------

model FeatureLogConfig {
  id        String   @id @default(uuid())
  guildId   String
  guild     Guild    @relation(fields: [guildId], references: [id], onDelete: Cascade)
  feature   String   // "INVENTORY" | "CENTRAL" | "REGISTRATION"
  channelId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([guildId, feature])
  @@map("feature_log_configs")
}
